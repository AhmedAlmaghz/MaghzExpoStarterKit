{
    "cli": {
        "version": ">= 13.0.0"
    },
    "build": {
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "preview"
            }
        },
        "production": {
            "distribution": "store",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal"
            }
        }
    }
}